# Copy to .env and fill in. All values have safe MVP defaults.

# Which transport the container runs (api | telegram | cli | all).
#   telegram = bot only · api = web only · all = bot + web + Mini App (one process)
APP_MODE=api
# Host port to publish the REST API on (container always listens on 8000).
HOST_PORT=8000
# Public HTTPS URL of the Mini App page for the bot's menu button (APP_MODE=all).
# e.g. https://<your-app>.up.railway.app/app
MINIAPP_URL=

# Application
APP_ENV=dev                 # dev | stage | prod
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# Database (MVP: SQLite via aiosqlite). Switch to PostgreSQL in prod:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/agent
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# LLM. Provider "mock" needs no keys and echoes deterministically.
# Set to "litellm" and provide a key to use a real provider.
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
# Real models via OpenRouter (one key, many models — see app/llm/catalog.py):
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# DEFAULT_MODEL=gpt-4o-mini          # which catalog model new users get
# LLM_EMBEDDING_MODEL=               # optional; openrouter defaults to a working one
# GEMINI_API_KEY=AQ...               # optional; routes catalog `gemini/*` to Google directly (free tier)

# Session memory window (number of recent messages kept in RAM)
MEMORY_SESSION_WINDOW=30

# Default communication style for new users (see app/persona.py)
DEFAULT_PERSONA=обычный

# Rate limiting (per user) — protects against spam and runaway API cost
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=15
RATE_LIMIT_PER_DAY=200

# Outbox relay (transactional event delivery)
OUTBOX_PUBLISHER_ENABLED=true   # background relay; set false to disable (e.g. tests)
OUTBOX_POLL_INTERVAL=1.0        # seconds between drain cycles
OUTBOX_MAX_ATTEMPTS=5           # retries before an event is dead-lettered

# Consumer-side idempotency (dedup window for at-least-once redeliveries)
IDEMPOTENCY_CACHE_SIZE=10000

# Telegram (only needed if you run the Telegram adapter)
TELEGRAM_BOT_TOKEN=

# REST API (only needed if you run `python -m app.main api`)
API_HOST=127.0.0.1
API_PORT=8000
